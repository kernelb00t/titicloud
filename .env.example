# ============================================================
# GLOBAL
# ============================================================
DOMAIN=thivillon.org

KUBE_MASTER_IP=100.x.x.x
SSH_USER=root
REMOTE_KUBECONFIG_PATH=/etc/rancher/k3s/k3s.yaml

# ============================================================
# NFS / SYNOLOGY NAS
# ============================================================
NFS_SERVER=192.168.1.x
NFS_MEDIA_PATH=/volume1/titiflix

# ============================================================
# GARAGE (S3 sur NAS Synology)
# ============================================================
GARAGE_HOST=192.168.1.x
GARAGE_ACCESS_KEY=CHANGE_ME
GARAGE_SECRET_KEY=CHANGE_ME

# ============================================================
# VELERO
# ============================================================
VELERO_BUCKET=velero-backups
CNPG_BUCKET=cnpg-backups

# ============================================================
# TRAEFIK
# ============================================================
ACME_EMAIL=CHANGE_ME@example.com

# Cloudflare -> Mon profil -> API Tokens -> Create Token
# template Edit zone DNS
# Zone Resources > sélectionne Include > Specific Zone > thivillon.org
CLOUDFLARE_DNS_API_TOKEN=ton_super_token_secret

# ============================================================
# AUTHENTIK
# ============================================================
# openssl rand -hex 32
AUTHENTIK_SECRET_KEY=CHANGE_ME
AUTHENTIK_DB_PASSWORD=CHANGE_ME
AUTHENTIK_DB_HOST=authentik-db-16-cluster-rw.auth.svc.cluster.local

# Mailcow SMTP settings for Authentik
AUTHENTIK_EMAIL_HOST=mail.example.com
AUTHENTIK_EMAIL_PORT=587
AUTHENTIK_EMAIL_USERNAME=authentik@example.com
AUTHENTIK_EMAIL_PASSWORD=CHANGE_ME
AUTHENTIK_EMAIL_FROM=authentik@example.com
AUTHENTIK_EMAIL_USE_TLS=true
AUTHENTIK_EMAIL_USE_SSL=false

# ============================================================
# PROTONVPN (Gluetun — qBittorrent)
# ============================================================
# Générer une config WireGuard depuis https://account.proton.me/u/0/vpn/WireGuard
# Cocher "NAT-PMP (Port Forwarding)" et choisir un serveur France P2P
# Copier la valeur de PrivateKey depuis le fichier .conf généré
PROTON_WIREGUARD_PRIVATE_KEY=CHANGE_ME

# ============================================================
# VAULTWARDEN
# ============================================================
# Generate with: openssl rand -base64 48
VAULTWARDEN_ADMIN_TOKEN=CHANGE_ME

# ============================================================
# SURE
# ============================================================
SURE_SECRET_KEY=CHANGE_ME
SURE_PRIMARY_KEY=CHANGE_ME
SURE_DETERMINISTIC_KEY=CHANGE_ME
SURE_SALT=CHANGE_ME

# Always use ASCII for that: openssl rand -hex 64
SURE_REDIS_PASSWORD=CHANGE_ME

# ============================================================
# TREK
# ============================================================
# Clé de chiffrement des secrets stockés
# Générer avec : openssl rand -hex 32
TREK_ENCRYPTION_KEY=CHANGE_ME

# ============================================================
# IMMICH
# ============================================================
# openssl rand -base64 32
IMMICH_DB_PASSWORD=CHANGE_ME

# Chemin NFS vers la bibliothèque de photos Immich (défaut : /volume1/immich)
NFS_IMMICH_PATH=/volume1/immich

# ============================================================
# PAPERLESS-NGX
# ============================================================
# openssl rand -hex 32
PAPERLESS_SECRET_KEY=CHANGE_ME
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=CHANGE_ME
PAPERLESS_ADMIN_MAIL=admin@example.com

PAPERLESS_EMAIL_HOST_PASSWORD=CHANGE_ME

# OIDC Settings
PAPERLESS_OIDC_CLIENT_ID=CHANGE_ME
PAPERLESS_OIDC_SECRET=CHANGE_ME
