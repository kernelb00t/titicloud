# ============================================================
# GLOBAL
# ============================================================
# Domain public du homelab (ex: example.com)
DOMAIN=thivillon.org

# IP, utilisateur du node k3s
KUBE_MASTER_IP=100.68.81.91 # deb13-k3s
SSH_USER=root
# Path de la config kube
REMOTE_KUBECONFIG_PATH=/etc/rancher/k3s/k3s.yaml

# ============================================================
# NFS / SYNOLOGY NAS
# ============================================================
# IP du NAS Synology pour NFS
NFS_SERVER=CHANGE_ME_NAS_IP
# Chemin NFS sur le NAS pour les médias
NFS_MEDIA_PATH=/volume1/media
# Chemin NFS pour les caches Immich (thumbnails, etc.)
NFS_CACHE_PATH=/volume1/cache

# ============================================================
# GARAGE (S3 sur NAS Synology)
# ============================================================
# Host/IP du NAS exposant Garage (ex: 192.168.1.100)
GARAGE_HOST=CHANGE_ME_GARAGE_HOST
# Access key Garage
GARAGE_ACCESS_KEY=CHANGE_ME_GARAGE_ACCESS_KEY
# Secret key Garage
GARAGE_SECRET_KEY=CHANGE_ME_GARAGE_SECRET_KEY

# ============================================================
# CLOUDNATIVEPG / POSTGRESQL
# ============================================================
# Authentik DB password
AUTHENTIK_DB_PASSWORD=CHANGE_ME_AUTHENTIK_DB_PASSWORD
# Authentik DB host (service CNPG k8s)
AUTHENTIK_DB_HOST=authentik-db-rw.auth.svc.cluster.local
# Immich DB password
IMMICH_DB_PASSWORD=CHANGE_ME_IMMICH_DB_PASSWORD
# Immich DB host
IMMICH_DB_HOST=immich-db-rw.photos.svc.cluster.local
# Affine DB password
AFFINE_DB_PASSWORD=CHANGE_ME_AFFINE_DB_PASSWORD
# Affine DB host
AFFINE_DB_HOST=affine-db-rw.productivity.svc.cluster.local
# N8N DB password
N8N_DB_PASSWORD=CHANGE_ME_N8N_DB_PASSWORD
# N8N DB host
N8N_DB_HOST=n8n-db-rw.productivity.svc.cluster.local

# ============================================================
# TRAEFIK (ingress, TLS via Let's Encrypt)
# ============================================================
# Email Let's Encrypt (used in HelmChartConfig for Traefik ACME)
ACME_EMAIL=CHANGE_ME_ACME_EMAIL

# ============================================================
# AUTHENTIK
# ============================================================
# Secret key Authentik (générer avec: openssl rand -hex 32)
AUTHENTIK_SECRET_KEY=CHANGE_ME_AUTHENTIK_SECRET_KEY

# ============================================================
# IMMICH
# ============================================================
# (pas de secret supplémentaire, utilise la DB CNPG)

# ============================================================
# AFFINE
# ============================================================
# (utilise la DB CNPG)

# ============================================================
# N8N
# ============================================================
# Clé de chiffrement n8n (générer avec: openssl rand -hex 24)
N8N_ENCRYPTION_KEY=CHANGE_ME_N8N_ENCRYPTION_KEY

# ============================================================
# VAULTWARDEN
# ============================================================
# Token admin Vaultwarden — DOIT être un hash Argon2.
# Générer avec (nécessite argon2 installé) :
#   echo -n "MON_MOT_DE_PASSE" | argon2 "$(openssl rand -base64 32)" -e -id -k 65536 -t 3 -p 4
# OU via Docker :
#   docker run --rm -it vaultwarden/server /vaultwarden hash --preset owasp
VAULTWARDEN_ADMIN_TOKEN=CHANGE_ME_VAULTWARDEN_ADMIN_TOKEN_ARGON2_HASH

# ============================================================
# QBITTORRENT / GLUETUN (WireGuard VPN)
# ============================================================
# Clé privée WireGuard
WIREGUARD_PRIVATE_KEY=CHANGE_ME_WIREGUARD_PRIVATE_KEY
# Adresse WireGuard du peer
WIREGUARD_ADDRESSES=CHANGE_ME_WIREGUARD_ADDRESSES
# Endpoint DNS du serveur VPN (ex: vpn.provider.com)
VPN_ENDPOINT_IP=CHANGE_ME_VPN_ENDPOINT_IP
# Port endpoint WireGuard
VPN_ENDPOINT_PORT=51820
# Clé publique du serveur WireGuard
WIREGUARD_PUBLIC_KEY=CHANGE_ME_WIREGUARD_PUBLIC_KEY

# ============================================================
# VELERO
# ============================================================
# (utilise GARAGE_ACCESS_KEY et GARAGE_SECRET_KEY)
# Bucket Garage à créer avant le déploiement de Velero
VELERO_BUCKET=velero-backups
# Bucket Garage pour les backups CNPG (à créer avant déploiement)
CNPG_BUCKET=cnpg-backups
